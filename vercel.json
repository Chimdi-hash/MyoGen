{
  "version": 2,
  "name": "myogen",
  "buildCommand": null,
  "outputDirectory": ".",
  "routes": [
    {
      "src": "^/$",
      "dest": "/index.html"
    },
    {
      "src": "^/register$",
      "dest": "/register.html"
    },
    {
      "src": "^/study$",
      "dest": "/study.html"
    },
    {
      "src": "^/explorer$",
      "dest": "/explorer.html"
    },
    {
      "src": "^/about$",
      "dest": "/about.html"
    },
    {
      "src": "^/(.*)\\.html$",
      "dest": "/$1.html"
    },
    {
      "src": "^/(.*)\\.css$",
      "dest": "/$1.css"
    },
    {
      "src": "^/(.*)\\.js$",
      "dest": "/$1.js"
    },
    {
      "src": "^/(.*)$",
      "dest": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/(.*)\\.(css|js|svg|png|jpg|jpeg|gif|ico|woff2)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
